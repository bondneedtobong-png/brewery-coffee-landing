<footer class="footer">
    <div class="container">
        <div class="footer__top">
            <div class="footer__brand">
                <a href="/" class="logo">
                    <span class="logo__mark" aria-hidden="true">
                        <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="20" cy="20" r="19" stroke="currentColor" stroke-width="1.2"/>
                            <path d="M14 28V14h8a4 4 0 010 8h-1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                            <path d="M22 22h2a3 3 0 010 6h-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                            <path d="M13 11l1.5 2M19 10l.5 3M25 11l-1 2.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                        </svg>
                    </span>
                    <span class="logo__text">
                        <span class="logo__name">Brewery Coffee</span>
                        <span class="logo__sub">est. 2017 · Moscow</span>
                    </span>
                </a>
                <p class="footer__tagline">Спешелти-кофе и&nbsp;своя обжарка в&nbsp;центре Москвы. Каждый день варим, пока за&nbsp;окном идёт жизнь.</p>
            </div>

            <div class="footer__col">
                <h4 class="footer__heading">Навигация</h4>
                <ul class="footer__list">
                    <li><a href="/#about">О&nbsp;нас</a></li>
                    <li><a href="/#menu">Меню</a></li>
                    <li><a href="/#atmosphere">Отзывы</a></li>
                    <li><a href="/#booking">Бронь</a></li>
                    <li><a href="/#contacts">Контакты</a></li>
                </ul>
            </div>

            <div class="footer__col">
                <h4 class="footer__heading">Аккаунт</h4>
                <ul class="footer__list">
                    <% if (locals.user) { %>
                        <li><a href="/profile">Личный кабинет</a></li>
                        <% if (user.role === 'admin' || user.role === 'moderator') { %>
                            <li><a href="/admin">Админка</a></li>
                        <% } %>
                    <% } else { %>
                        <li><a href="/auth/login">Войти</a></li>
                        <li><a href="/auth/register">Регистрация</a></li>
                    <% } %>
                    <li><a href="/privacy">Политика конфиденциальности</a></li>
                </ul>
            </div>

            <div class="footer__col">
                <h4 class="footer__heading">Контакты</h4>
                <ul class="footer__list">
                    <li>Большая Дмитровка,&nbsp;14</li>
                    <li><a href="tel:+74951234567">+7 (495) 123-45-67</a></li>
                    <li><a href="mailto:hello@brewery.coffee">hello@brewery.coffee</a></li>
                    <li>Пн–Вс &nbsp;08:00&nbsp;– 23:00</li>
                </ul>
                <div class="footer__socials">
                    <a href="#" aria-label="Telegram" class="social">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M22 3L2 10l6 2 2 7 4-5 7 5 1-16z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                        </svg>
                    </a>
                    <a href="#" aria-label="Instagram" class="social">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.6"/>
                            <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.6"/>
                            <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
                        </svg>
                    </a>
                    <a href="#" aria-label="VK" class="social">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M4 8c0 6 4 10 10 10h2v-3l4 3c1-1 1-2 0-3l-2-2 2-2c1-1 1-2 0-3h-3l-3 3v-3H10v3c-2 0-3-2-3-5H4z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                        </svg>
                    </a>
                </div>
            </div>
        </div>

        <div class="footer__divider"></div>

        <div class="footer__bottom">
            <p class="footer__copy">© 2017–2026 Brewery Coffee. Демо-проект для&nbsp;портфолио.</p>
            <ul class="footer__legal">
                <li><a href="/privacy">Политика конфиденциальности</a></li>
            </ul>
        </div>
    </div>

    <div class="footer__brand-line" aria-hidden="true">BREWERY · COFFEE</div>
</footer>

<% if (locals.flash) { %>
    <div class="flash flash--<%= flash.type %>" id="flash">
        <span><%- flash.message %></span>
        <button type="button" onclick="this.parentElement.remove()" aria-label="Закрыть">×</button>
    </div>
    <script>setTimeout(() => { const f = document.getElementById('flash'); if (f) f.remove(); }, 5000);</script>
<% } %>
