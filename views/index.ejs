<%- include('partials/head', { title: null, meta: 'Brewery Coffee — крафтовое кафе в сердце Москвы. Спешелти-кофе, обжарка на месте, программа лояльности на 10 уровней.' }) %>
<body>
    <%- include('partials/topbar') %>
    <%- include('partials/header') %>

    <!-- Hero -->
    <section class="hero" id="hero">
        <div class="hero__bg" aria-hidden="true">
            <img src="https://images.unsplash.com/photo-1453614512568-c4024d13c247?auto=format&fit=crop&w=2200&q=80" alt="" loading="eager">
        </div>
        <div class="hero__overlay" aria-hidden="true"></div>

        <div class="container hero__container">
            <div class="hero__content">
                <p class="hero__eyebrow">
                    <span class="hero__eyebrow-line" aria-hidden="true"></span>
                    Speciality · Roastery · Москва
                </p>
                <h1 class="hero__title">
                    Крафтовый кофе
                    <span class="hero__title-em">в&nbsp;сердце</span>
                    Москвы.
                </h1>
                <p class="hero__subtitle">Обжариваем зерно в&nbsp;день варки, варим на&nbsp;воде после обратного осмоса и&nbsp;разрешаем сидеть с&nbsp;ноутбуком до&nbsp;самого закрытия.</p>

                <div class="hero__actions">
                    <a href="#menu" class="btn btn--accent">
                        <span>Посмотреть меню</span>
                        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 8h11M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                    <% if (locals.user) { %>
                        <a href="/profile" class="btn btn--ghost">Личный кабинет</a>
                    <% } else { %>
                        <a href="/auth/register" class="btn btn--ghost">Регистрация в&nbsp;клубе</a>
                    <% } %>
                </div>

                <ul class="hero__facts">
                    <li>
                        <span class="hero__fact-num">7</span>
                        <span class="hero__fact-label">лет на&nbsp;карте<br>спешелти-Москвы</span>
                    </li>
                    <li>
                        <span class="hero__fact-num">10</span>
                        <span class="hero__fact-label">уровней<br>программы лояльности</span>
                    </li>
                    <li>
                        <span class="hero__fact-num"><%= reviewStats.avg %></span>
                        <span class="hero__fact-label">средний рейтинг<br>от&nbsp;<%= reviewStats.count %>&nbsp;отзывов</span>
                    </li>
                </ul>
            </div>

            <aside class="hero__card" aria-hidden="true">
                <div class="hero__card-img">
                    <img src="/assets/images/hero-coffee-bag.jpg" alt="Свежеобжаренное зерно Brewery Coffee" loading="eager">
                </div>
                <div class="hero__card-info">
                    <p class="hero__card-eyebrow">Roast of the week</p>
                    <h3 class="hero__card-title">Эфиопия<br>Yirgacheffe G1</h3>
                    <div class="hero__card-meta">
                        <span>Цитрус · Жасмин · Мёд</span>
                        <span class="hero__card-score">SCA <strong>87.5</strong></span>
                    </div>
                </div>
                <div class="hero__badge">
                    <span class="hero__badge-num">№1</span>
                    <span class="hero__badge-text">по&nbsp;спешелти<br>в&nbsp;Тверском&nbsp;р-не</span>
                </div>
            </aside>
        </div>

        <a href="#about" class="hero__scroll" aria-label="К следующей секции">
            <span class="hero__scroll-line" aria-hidden="true"></span>
            <span class="hero__scroll-label">Листайте вниз</span>
        </a>

        <div class="hero__marquee" aria-hidden="true">
            <div class="hero__marquee-track">
                <span>Speciality coffee</span><span class="hero__marquee-sep">✦</span>
                <span>Single origin</span><span class="hero__marquee-sep">✦</span>
                <span>In-house roastery</span><span class="hero__marquee-sep">✦</span>
                <span>Loyalty club</span><span class="hero__marquee-sep">✦</span>
                <span>Speciality coffee</span><span class="hero__marquee-sep">✦</span>
                <span>Single origin</span><span class="hero__marquee-sep">✦</span>
                <span>In-house roastery</span><span class="hero__marquee-sep">✦</span>
                <span>Loyalty club</span><span class="hero__marquee-sep">✦</span>
            </div>
        </div>
    </section>

    <!-- About -->
    <section class="about section" id="about">
        <div class="container">
            <div class="about__top">
                <div class="about__intro">
                    <p class="section__eyebrow">О&nbsp;нас</p>
                    <h2 class="section__title">Кафе, в&nbsp;котором кофе&nbsp;— <em>ремесло</em></h2>
                    <p class="section__lead">С&nbsp;2017&nbsp;года мы&nbsp;ищем зерно по&nbsp;всему миру, привозим небольшими партиями и&nbsp;обжариваем прямо в&nbsp;зале — за&nbsp;деревянной перегородкой, под&nbsp;старые джазовые пластинки и&nbsp;шум маленького турбийона.</p>
                </div>

                <figure class="about__media reveal">
                    <img src="https://images.unsplash.com/photo-1554118811-1e0d58224f24?auto=format&fit=crop&w=1100&q=80" alt="Интерьер кафе Brewery Coffee" loading="lazy">
                    <figcaption class="about__media-tag">
                        <span class="about__media-line"></span>
                        Главный зал, 14&nbsp;столов
                    </figcaption>
                    <div class="about__media-plaque">
                        <span class="about__media-plaque-num">7</span>
                        <span class="about__media-plaque-text">лет<br>в&nbsp;центре Москвы</span>
                    </div>
                </figure>
            </div>

            <div class="features">
                <article class="feature reveal">
                    <span class="feature__num">01</span>
                    <span class="feature__icon" aria-hidden="true">
                        <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <ellipse cx="18" cy="12" rx="7" ry="9" stroke="currentColor" stroke-width="1.6"/>
                            <path d="M18 3v18" stroke="currentColor" stroke-width="1.6"/>
                            <ellipse cx="18" cy="26" rx="7" ry="6" stroke="currentColor" stroke-width="1.6"/>
                            <path d="M18 20v12" stroke="currentColor" stroke-width="1.6"/>
                        </svg>
                    </span>
                    <h3 class="feature__title">Спешелти-зерно</h3>
                    <p class="feature__text">Только зерно с&nbsp;оценкой 85+&nbsp;по&nbsp;шкале&nbsp;SCA. Прямые контракты с&nbsp;фермами Эфиопии, Колумбии и&nbsp;Кении.</p>
                </article>

                <article class="feature reveal">
                    <span class="feature__num">02</span>
                    <span class="feature__icon" aria-hidden="true">
                        <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect x="6" y="11" width="24" height="18" rx="3" stroke="currentColor" stroke-width="1.6"/>
                            <circle cx="18" cy="20" r="5" stroke="currentColor" stroke-width="1.6"/>
                            <circle cx="18" cy="20" r="1.5" fill="currentColor"/>
                            <path d="M11 5c1.5 1.5 0 3 1.5 4.5M18 4c1.5 1.5 0 3 1.5 4.5M25 5c1.5 1.5 0 3 1.5 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                            <circle cx="26" cy="15" r="1" fill="currentColor"/>
                        </svg>
                    </span>
                    <h3 class="feature__title">Обжарка на&nbsp;месте</h3>
                    <p class="feature__text">Ростер&nbsp;Probat&nbsp;15&nbsp;кг работает четыре раза в&nbsp;неделю. Свежее зерно в&nbsp;вашей чашке через&nbsp;48&nbsp;часов.</p>
                </article>

                <article class="feature reveal">
                    <span class="feature__num">03</span>
                    <span class="feature__icon" aria-hidden="true">
                        <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M18 4l2.5 6.5L27 12l-5 4 2 7-6-3.5L12 23l2-7-5-4 6.5-1.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                            <path d="M12 30h12M14 33h8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                        </svg>
                    </span>
                    <h3 class="feature__title">Бариста-чемпионы</h3>
                    <p class="feature__text">В&nbsp;команде призёры&nbsp;Russian Barista Championship и&nbsp;Brewers&nbsp;Cup. Готовим конкурсантов и&nbsp;судим чемпионаты.</p>
                </article>

                <article class="feature reveal">
                    <span class="feature__num">04</span>
                    <span class="feature__icon" aria-hidden="true">
                        <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M18 4 L22 16 L34 16 L24 24 L28 34 L18 27 L8 34 L12 24 L2 16 L14 16 Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" fill="none"/>
                        </svg>
                    </span>
                    <h3 class="feature__title">Бонусная программа</h3>
                    <p class="feature__text">10&nbsp;уровней с&nbsp;накопительной скидкой от&nbsp;3% до&nbsp;20%. Бесплатный кофе каждую неделю за&nbsp;тёплый отзыв.</p>
                </article>
            </div>

            <div class="stats reveal">
                <div class="stat">
                    <span class="stat__value" data-count="7">7</span>
                    <span class="stat__sep">·</span>
                    <span class="stat__label">лет на&nbsp;карте Москвы</span>
                </div>
                <div class="stat">
                    <span class="stat__value" data-count="42">42</span>
                    <span class="stat__sep">·</span>
                    <span class="stat__label">сорта зерна за&nbsp;год</span>
                </div>
                <div class="stat">
                    <span class="stat__value" data-count="<%= reviewStats.count %>"><%= reviewStats.count %></span>
                    <span class="stat__sep">·</span>
                    <span class="stat__label">отзывов гостей</span>
                </div>
                <div class="stat">
                    <span class="stat__value"><%= reviewStats.avg %></span>
                    <span class="stat__sep">·</span>
                    <span class="stat__label">средний рейтинг</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Menu — Bar card (typography only, drinks only, DB-driven) -->
    <section class="menu menu--card section section--alt" id="menu">
        <div class="container">
            <div class="section__head section__head--row">
                <div>
                    <p class="section__eyebrow">Барная карта</p>
                    <h2 class="section__title">Сегодня <em>наливаем</em></h2>
                </div>
                <p class="section__lead section__lead--short">Карта меняется раз в&nbsp;две недели — следим за&nbsp;сезонностью зерна и&nbsp;настроением шефа. Полное меню с&nbsp;десертами и&nbsp;завтраками — в&nbsp;кафе.</p>
            </div>

            <% const categoryLabels = { espresso: 'Эспрессо-машина', alternative: 'Альтернатива' }; %>
            <% const categoryNumerals = { espresso: 'I', alternative: 'II' }; %>
            <% for (const cat of ['espresso', 'alternative']) { %>
                <% const items = menuByCat[cat] || []; %>
                <% if (items.length) { %>
                    <div class="bar-card">
                        <header class="bar-card__head">
                            <span class="bar-card__num"><%= categoryNumerals[cat] %></span>
                            <h3 class="bar-card__title"><%= categoryLabels[cat] %></h3>
                            <span class="bar-card__rule" aria-hidden="true"></span>
                        </header>

                        <ul class="bar-card__list">
                            <% items.forEach((item, idx) => { %>
                                <li class="bar-card__row<%= item.is_hit ? ' is-hit' : '' %><%= item.is_new ? ' is-new' : '' %>">
                                    <div class="bar-card__main">
                                        <h4 class="bar-card__name">
                                            <%= item.title %>
                                            <% if (item.is_hit) { %><span class="bar-card__flag bar-card__flag--hit" aria-label="Хит">★</span><% } %>
                                            <% if (item.is_new) { %><span class="bar-card__flag bar-card__flag--new" aria-label="Новинка">new</span><% } %>
                                        </h4>
                                        <% if (item.description) { %>
                                            <p class="bar-card__desc"><%= item.description %></p>
                                        <% } %>
                                        <% if (item.tags) { %>
                                            <ul class="bar-card__tags">
                                                <% item.tags.split(',').map(t => t.trim()).filter(Boolean).forEach(tag => { %>
                                                    <li><%= tag %></li>
                                                <% }) %>
                                            </ul>
                                        <% } %>
                                    </div>
                                    <div class="bar-card__leaders" aria-hidden="true"></div>
                                    <div class="bar-card__side">
                                        <% if (item.volume) { %><span class="bar-card__vol"><%= item.volume %></span><% } %>
                                        <span class="bar-card__price"><%= item.price %>&nbsp;₽</span>
                                    </div>
                                </li>
                            <% }) %>
                        </ul>
                    </div>
                <% } %>
            <% } %>

            <div class="menu__foot">
                <p>Полное меню с&nbsp;десертами и&nbsp;завтраками&nbsp;— в&nbsp;кафе и&nbsp;по&nbsp;запросу</p>
                <a href="#booking" class="link-arrow">Забронировать стол
                    <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 8h11M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
            </div>
        </div>
    </section>

    <!-- Reviews — replaces atmosphere gallery -->
    <section class="reviews section" id="atmosphere">
        <div class="container">
            <div class="section__head section__head--row">
                <div>
                    <p class="section__eyebrow">Отзывы гостей</p>
                    <h2 class="section__title">Здесь хочется<br><em>задержаться</em></h2>
                </div>
                <div class="reviews__summary">
                    <div class="reviews__score">
                        <span class="reviews__avg"><%= reviewStats.avg %></span>
                        <div class="stars stars--lg" aria-label="<%= reviewStats.avg %> из 5">
                            <% for (let i = 1; i <= 5; i++) { %>
                                <span class="star <%= i <= Math.round(reviewStats.avg) ? 'star--filled' : '' %>">★</span>
                            <% } %>
                        </div>
                    </div>
                    <p class="reviews__count"><%= reviewStats.count %>&nbsp;<%= ruPluralize(reviewStats.count, ['одобренный отзыв', 'одобренных отзыва', 'одобренных отзывов']) %> от&nbsp;постоянных гостей</p>
                </div>
            </div>

            <div class="reviews__head-cta">
                <% if (locals.user) { %>
                    <a href="/reviews/new" class="btn btn--accent">
                        <span>Оставить отзыв</span>
                        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 8h11M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                <% } else { %>
                    <a href="/auth/login?next=/reviews/new" class="btn btn--ghost">
                        Войти, чтобы оставить отзыв
                    </a>
                <% } %>
            </div>

            <div class="reviews__grid">
                <% if (!reviews.length) { %>
                    <div class="reviews__empty">Скоро здесь появятся отзывы.</div>
                <% } else { %>
                    <% reviews.forEach((r, idx) => { %>
                        <article class="review-card<%= idx === 0 ? ' review-card--feature' : '' %>" style="--accent-img: url('<%= reviewBgs[idx % reviewBgs.length] %>')">
                            <div class="review-card__head">
                                <div class="review-card__avatar" aria-hidden="true">
                                    <%= (r.name || '?').trim().charAt(0).toUpperCase() %>
                                </div>
                                <div>
                                    <p class="review-card__name"><%= r.name.split(' ')[0] %></p>
                                    <p class="review-card__meta">
                                        L<%= r.level %> · <%= r.discount_pct %>%
                                        <span class="review-card__dot">·</span>
                                        <%= formatReviewDate(r.created_at) %>
                                    </p>
                                </div>
                                <div class="stars" aria-label="<%= r.rating %> из 5">
                                    <% for (let i = 1; i <= 5; i++) { %>
                                        <span class="star <%= i <= r.rating ? 'star--filled' : '' %>">★</span>
                                    <% } %>
                                </div>
                            </div>
                            <blockquote class="review-card__text"><%= r.text %></blockquote>
                        </article>
                    <% }) %>
                <% } %>
            </div>
        </div>
    </section>

    <!-- Booking -->
    <section class="booking section section--alt" id="booking">
        <div class="container booking__container">
            <aside class="booking__intro">
                <p class="section__eyebrow">Бронирование</p>
                <h2 class="section__title">Оставьте<br>стол <em>за&nbsp;собой</em></h2>
                <p class="section__lead">У&nbsp;нас 14&nbsp;столов и&nbsp;большой общий стол у&nbsp;окна. По&nbsp;вечерам пятницы и&nbsp;субботы рекомендуем бронировать заранее.</p>

                <ul class="booking__features">
                    <li class="reveal">
                        <span class="booking__feature-num">01</span>
                        <span class="booking__feature-text">Бронь держим 15&nbsp;минут после указанного времени</span>
                    </li>
                    <li class="reveal">
                        <span class="booking__feature-num">02</span>
                        <span class="booking__feature-text">Перезвоним и&nbsp;подтвердим в&nbsp;течение часа</span>
                    </li>
                    <li class="reveal">
                        <span class="booking__feature-num">03</span>
                        <span class="booking__feature-text">Дети, собаки и&nbsp;ноутбуки — самые желанные гости</span>
                    </li>
                </ul>

                <figure class="booking__schematic reveal" aria-hidden="true">
                    <figcaption class="booking__schematic-head">
                        <span class="booking__schematic-eyebrow">Ваш стол</span>
                        <span class="booking__schematic-counter" id="seatCounter">Выберите количество гостей</span>
                    </figcaption>
                    <svg viewBox="0 0 400 400" class="booking-table" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <radialGradient id="tableTop" cx="50%" cy="50%">
                                <stop offset="0%" stop-color="#3a2e22"/>
                                <stop offset="55%" stop-color="#241c14"/>
                                <stop offset="100%" stop-color="#1a140e"/>
                            </radialGradient>
                            <radialGradient id="cupRim" cx="50%" cy="50%">
                                <stop offset="0%" stop-color="#7a5a3a"/>
                                <stop offset="100%" stop-color="#2a1f15"/>
                            </radialGradient>
                        </defs>

                        <circle cx="200" cy="200" r="170" fill="none" stroke="rgba(212,176,122,0.08)" stroke-dasharray="2 8" stroke-width="1"/>
                        <circle cx="200" cy="200" r="140" fill="none" stroke="rgba(212,176,122,0.04)"/>

                        <circle cx="200" cy="200" r="92" fill="url(#tableTop)" stroke="rgba(212,176,122,0.32)" stroke-width="1.5"/>
                        <circle cx="200" cy="200" r="62" fill="none" stroke="rgba(212,176,122,0.13)" stroke-width="1"/>
                        <circle cx="200" cy="200" r="38" fill="none" stroke="rgba(212,176,122,0.08)" stroke-width="1"/>

                        <g class="booking-table__cup" transform="translate(200 200)">
                            <circle r="26" fill="url(#cupRim)" stroke="rgba(212,176,122,0.5)" stroke-width="1.5"/>
                            <circle r="20" fill="rgba(20,16,12,0.95)"/>
                            <circle r="14" fill="rgba(120,85,55,0.55)"/>
                            <circle r="8" fill="rgba(60,40,28,0.95)"/>
                            <g class="booking-table__steam" stroke="rgba(212,176,122,0.5)" fill="none" stroke-linecap="round" stroke-width="1.6">
                                <path d="M-8 -28 q-4 -10 0 -22 q4 -10 0 -22"/>
                                <path d="M 0 -28 q 4 -10 0 -22 q-4 -10 0 -22"/>
                                <path d="M 8 -28 q-4 -10 0 -22 q4 -10 0 -22"/>
                            </g>
                        </g>

                        <g class="seat" data-seat="1" transform="translate(200 68) rotate(0)">
                            <path d="M-26 4 q0 -28 26 -28 q26 0 26 28" stroke="rgba(212,176,122,0.42)" fill="none" stroke-width="1.8" class="seat__back"/>
                            <circle r="13" class="seat__person" fill="rgba(60,42,28,0.75)" stroke="rgba(212,176,122,0.6)" stroke-width="2"/>
                        </g>
                        <g class="seat" data-seat="2" transform="translate(314.3 134) rotate(60)">
                            <path d="M-26 4 q0 -28 26 -28 q26 0 26 28" stroke="rgba(212,176,122,0.42)" fill="none" stroke-width="1.8" class="seat__back"/>
                            <circle r="13" class="seat__person" fill="rgba(60,42,28,0.75)" stroke="rgba(212,176,122,0.6)" stroke-width="2"/>
                        </g>
                        <g class="seat" data-seat="3" transform="translate(314.3 266) rotate(120)">
                            <path d="M-26 4 q0 -28 26 -28 q26 0 26 28" stroke="rgba(212,176,122,0.42)" fill="none" stroke-width="1.8" class="seat__back"/>
                            <circle r="13" class="seat__person" fill="rgba(60,42,28,0.75)" stroke="rgba(212,176,122,0.6)" stroke-width="2"/>
                        </g>
                        <g class="seat" data-seat="4" transform="translate(200 332) rotate(180)">
                            <path d="M-26 4 q0 -28 26 -28 q26 0 26 28" stroke="rgba(212,176,122,0.42)" fill="none" stroke-width="1.8" class="seat__back"/>
                            <circle r="13" class="seat__person" fill="rgba(60,42,28,0.75)" stroke="rgba(212,176,122,0.6)" stroke-width="2"/>
                        </g>
                        <g class="seat" data-seat="5" transform="translate(85.7 266) rotate(240)">
                            <path d="M-26 4 q0 -28 26 -28 q26 0 26 28" stroke="rgba(212,176,122,0.42)" fill="none" stroke-width="1.8" class="seat__back"/>
                            <circle r="13" class="seat__person" fill="rgba(60,42,28,0.75)" stroke="rgba(212,176,122,0.6)" stroke-width="2"/>
                        </g>
                        <g class="seat" data-seat="6" transform="translate(85.7 134) rotate(300)">
                            <path d="M-26 4 q0 -28 26 -28 q26 0 26 28" stroke="rgba(212,176,122,0.42)" fill="none" stroke-width="1.8" class="seat__back"/>
                            <circle r="13" class="seat__person" fill="rgba(60,42,28,0.75)" stroke="rgba(212,176,122,0.6)" stroke-width="2"/>
                        </g>

                        <g class="seat-extra" id="seatExtra" transform="translate(360 200)">
                            <circle r="18" fill="rgba(14,12,10,0.85)" stroke="rgba(212,176,122,0.5)" stroke-width="1.6" stroke-dasharray="3 3"/>
                            <text y="5" text-anchor="middle" fill="rgba(212,176,122,0.7)" font-family="Cormorant Garamond, serif" font-size="14" font-style="italic" font-weight="600">+1</text>
                        </g>
                    </svg>

                    <div class="booking__schematic-legend">
                        <span class="booking__schematic-legend-item"><span class="booking__schematic-dot"></span> Свободно</span>
                        <span class="booking__schematic-legend-item booking__schematic-legend-item--filled"><span class="booking__schematic-dot booking__schematic-dot--filled"></span> Занято вами</span>
                    </div>
                </figure>
            </aside>

            <form class="booking__form reveal" id="bookingForm" novalidate>
                <div class="booking__form-head">
                    <p class="booking__form-eyebrow">Онлайн-бронь · бесплатно</p>
                    <h3 class="booking__form-title">Какой стол ищем?</h3>
                </div>

                <div class="form-row">
                    <div class="form-field">
                        <label class="form-label" for="name">Имя</label>
                        <input class="form-input" type="text" id="name" name="name" placeholder="Как к&nbsp;вам обращаться?" value="<%= locals.user ? user.name : '' %>" required>
                        <span class="form-error" data-for="name"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-field">
                        <label class="form-label" for="phone">Телефон</label>
                        <input class="form-input" type="tel" id="phone" name="phone" placeholder="+7 (___) ___-__-__" value="<%= locals.displayPhone || '' %>" required>
                        <span class="form-error" data-for="phone"></span>
                    </div>
                </div>

                <div class="form-row form-row--two">
                    <div class="form-field">
                        <label class="form-label" for="date">Дата</label>
                        <input class="form-input" type="date" id="date" name="date" required>
                        <span class="form-error" data-for="date"></span>
                    </div>
                    <div class="form-field">
                        <label class="form-label" for="time">Время</label>
                        <input class="form-input" type="time" id="time" name="time" required>
                        <span class="form-error" data-for="time"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-field">
                        <label class="form-label" for="guests">Гостей</label>
                        <select class="form-input" id="guests" name="guests" required>
                            <option value="">Сколько вас будет?</option>
                            <option value="1">1 гость</option>
                            <option value="2">2 гостя</option>
                            <option value="3">3 гостя</option>
                            <option value="4">4 гостя</option>
                            <option value="5">5 гостей</option>
                            <option value="6">6 гостей</option>
                            <option value="7+">Больше 6</option>
                        </select>
                        <span class="form-error" data-for="guests"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-field">
                        <label class="form-label" for="comment">Комментарий <span class="form-label__opt">(необязательно)</span></label>
                        <textarea class="form-input" id="comment" name="comment" rows="3" placeholder="Особый повод, пожелания по&nbsp;столу..."></textarea>
                    </div>
                </div>

                <button type="submit" class="btn btn--accent btn--block">
                    <span>Забронировать стол</span>
                    <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 8h11M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>

                <p class="form-meta">Нажимая «Забронировать», вы&nbsp;соглашаетесь с&nbsp;<a href="/privacy">политикой обработки данных</a>.</p>

                <p class="form-success" id="formSuccess" hidden>
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    Спасибо, мы&nbsp;свяжемся с&nbsp;вами в&nbsp;течение часа и&nbsp;подтвердим бронь.
                </p>
            </form>
        </div>
    </section>

    <!-- Contacts -->
    <section class="contacts section" id="contacts">
        <div class="container">
            <div class="section__head section__head--row">
                <div>
                    <p class="section__eyebrow">Контакты</p>
                    <h2 class="section__title">Найдите нас<br><em>в&nbsp;центре города</em></h2>
                </div>
                <p class="section__lead section__lead--short">Большая Дмитровка, в&nbsp;3&nbsp;минутах от&nbsp;метро. Заходите с&nbsp;улицы — деревянная дверь между галереей и&nbsp;винотекой.</p>
            </div>

            <div class="contacts__grid">
                <div class="contacts__map reveal" aria-label="Карта">
                    <div class="contacts__map-image">
                        <img src="https://images.unsplash.com/photo-1559925393-8be0ec4767c8?auto=format&fit=crop&w=1400&q=80" alt="Фасад кафе" loading="lazy">
                    </div>
                    <div class="contacts__map-overlay"></div>
                    <div class="contacts__map-grid" aria-hidden="true"></div>

                    <a href="https://yandex.ru/maps/?text=Москва%2C+ул.+Большая+Дмитровка%2C+14" target="_blank" rel="noopener" class="contacts__map-pin">
                        <span class="contacts__map-pin-ping"></span>
                        <span class="contacts__map-pin-dot">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M12 22s8-7 8-13a8 8 0 10-16 0c0 6 8 13 8 13z" fill="currentColor"/>
                                <circle cx="12" cy="9" r="3" fill="#0F0D0B"/>
                            </svg>
                        </span>
                        <span class="contacts__map-pin-label">
                            <strong>Brewery Coffee</strong>
                            ул.&nbsp;Большая Дмитровка,&nbsp;14
                        </span>
                    </a>

                    <a href="https://yandex.ru/maps/?text=Москва%2C+ул.+Большая+Дмитровка%2C+14" target="_blank" rel="noopener" class="contacts__map-cta">
                        Открыть в&nbsp;Яндекс.Картах
                        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5 3h8v8M13 3L3 13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                </div>

                <div class="contacts__info">
                    <article class="contact-card reveal">
                        <div class="contact-card__icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M12 22s8-7 8-13a8 8 0 10-16 0c0 6 8 13 8 13z" stroke="currentColor" stroke-width="1.6"/>
                                <circle cx="12" cy="9" r="3" stroke="currentColor" stroke-width="1.6"/>
                            </svg>
                        </div>
                        <h3 class="contact-card__title">Адрес</h3>
                        <p class="contact-card__text">Москва, Большая Дмитровка,&nbsp;14<br><span class="contact-card__dim">м.&nbsp;Театральная, 4&nbsp;минуты пешком</span></p>
                    </article>

                    <article class="contact-card reveal">
                        <div class="contact-card__icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <h3 class="contact-card__title">Связь</h3>
                        <p class="contact-card__text">
                            <a href="tel:+74951234567">+7 (495) 123-45-67</a><br>
                            <a href="mailto:hello@brewery.coffee">hello@brewery.coffee</a>
                        </p>
                    </article>

                    <article class="contact-card reveal">
                        <div class="contact-card__icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.6"/>
                                <path d="M12 6v6l4 2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                            </svg>
                        </div>
                        <h3 class="contact-card__title">Часы работы</h3>
                        <p class="contact-card__text">Пн&nbsp;– Пт &nbsp;08:00&nbsp;– 23:00<br>Сб&nbsp;– Вс &nbsp;09:00&nbsp;– 00:00</p>
                    </article>

                    <article class="contact-card reveal">
                        <div class="contact-card__icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.6"/>
                                <path d="M12 6c-3 4-3 8 0 12M12 6c3 4 3 8 0 12M2 12h20" stroke="currentColor" stroke-width="1.6"/>
                            </svg>
                        </div>
                        <h3 class="contact-card__title">Соцсети</h3>
                        <p class="contact-card__text contact-card__socials">
                            <a href="#">Telegram</a>
                            <a href="#">Instagram</a>
                            <a href="#">VK</a>
                        </p>
                    </article>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA banner — loyalty club -->
    <section class="cta">
        <div class="container">
            <div class="cta__inner">
                <div>
                    <p class="cta__eyebrow"><% if (locals.user) { %>Вы в клубе<% } else { %>Вступайте в&nbsp;клуб<% } %></p>
                    <% if (locals.user) { %>
                        <h2 class="cta__title">L<%= userTier.level %> · скидка <%= userTier.discount %>%. <%= userPerk.text %></h2>
                    <% } else { %>
                        <h2 class="cta__title">10&nbsp;уровней скидки от&nbsp;3% до&nbsp;20% — копится по&nbsp;номеру телефона навсегда</h2>
                    <% } %>
                </div>
                <% if (locals.user) { %>
                    <a href="/profile" class="btn btn--accent">
                        <span>Открыть кабинет</span>
                        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 8h11M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                <% } else { %>
                    <a href="/auth/register" class="btn btn--accent">
                        <span>Зарегистрироваться</span>
                        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 8h11M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                <% } %>
            </div>
        </div>
    </section>

    <%- include('partials/footer') %>

    <script src="/scripts/main.js?v=8"></script>
    <script src="/scripts/form.js?v=8"></script>
</body>
</html>
